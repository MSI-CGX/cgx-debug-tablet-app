{
  "name": "cgx-debug-tablet",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "icons": "node scripts/generate-app-icon.mjs",
    "postinstall": "electron-builder install-app-deps",
    "stage-env": "node scripts/stage-env.cjs",
    "build:unpack": "npm run build && npm run icons && npm run stage-env && electron-builder --dir",
    "build:win": "npm run build && npm run icons && npm run stage-env && electron-builder --win",
    "build:mac": "npm run build && npm run icons && npm run stage-env && electron-builder --mac",
    "build:linux": "npm run build && npm run icons && npm run stage-env && electron-builder --linux",
    "ui:add": "npx shadcn@latest add --yes --overwrite --cwd src/renderer/src"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "electron-store": "^8.2.0",
    "i18next": "^26.0.4",
    "leaflet": "^1.9.4",
    "lmdb": "^3.5.3",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react-i18next": "^17.0.2",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rushstack/eslint-patch": "^1.7.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^18.19.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
